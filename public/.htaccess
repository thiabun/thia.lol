Options -Indexes -MultiViews

DirectoryIndex index.html

AddType image/jpeg .jpg .jpeg
AddType image/png .png
AddType image/webp .webp
AddType image/gif .gif
AddType video/mp4 .mp4
AddType video/webm .webm

<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(?:js|css|woff2?|ttf|otf|eot|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:webp|avif|jpe?g|gif|ico|mp4|m4v|webm)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 7 days"
  ExpiresByType image/avif "access plus 7 days"
  ExpiresByType image/jpeg "access plus 7 days"
  ExpiresByType image/gif "access plus 7 days"
  ExpiresByType image/x-icon "access plus 7 days"
  ExpiresByType video/mp4 "access plus 7 days"
  ExpiresByType video/x-m4v "access plus 7 days"
  ExpiresByType video/webm "access plus 7 days"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Keep future PHP/MySQL API routes outside the React SPA rewrite.
  RewriteCond %{REQUEST_URI} ^/api(?:/|$) [NC]
  RewriteRule ^ - [L]

  RewriteRule ^sitemap\.xml$ api/sitemap.php [QSA,L]

  # Serve post-specific Open Graph metadata before the React app hydrates.
  RewriteRule ^@([A-Za-z0-9_-]{1,40})/posts/([A-Za-z0-9_-]{1,40})/?$ api/post-share.php?handle=$1&postId=$2 [QSA,L]

  # Serve profile-specific Open Graph metadata before the React app hydrates.
  RewriteRule ^@([A-Za-z0-9_-]{1,40})/?$ api/profile-share.php?handle=$1 [QSA,L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [END]

  RewriteRule ^ index.html [L]
</IfModule>
