{
  "name": "thia-lol",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run optimize:assets && tsc -b && vite build",
    "dev:api": "tsx watch server/src/index.ts",
    "build:api": "tsc -p tsconfig.server.json",
    "start:api": "node server/dist/index.js",
    "test:api": "vitest run server",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "THIA_USE_TEST_CONFIG=1 PLAYWRIGHT_NO_WEBSERVER=1 playwright test tests/smoke",
    "typecheck": "tsc -b --pretty && tsc -p tsconfig.server.json --noEmit --pretty",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-react": "6.0.2",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "html-to-image": "^1.11.13",
    "lucide-react": "1.17.0",
    "motion": "12.40.0",
    "mysql2": "^3.22.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.6.0",
    "react-router": "7.17.0",
    "tweetnacl": "^1.0.3",
    "vite": "8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "sharp": "0.34.5",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.1.9"
  }
}
